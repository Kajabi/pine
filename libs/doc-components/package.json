{
  "name": "@pine-ds/doc-components",
  "version": "0.0.1",
  "license": "MIT",
  "description": "Documentation Web Components used for Pine Documentation Site",
  "keywords": [
    "stencil",
    "web components"
  ],
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "es2015": "dist/esm/index.js",
  "es2017": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/doc-components/doc-components.esm.js",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/",
    "directory": "dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kajabi/pine.git"
  },
  "bugs": {
    "url": "https://github.com/kajab/pine/issues"
  },
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "build.stencil": "stencil build --docs",
    "start.stencil": "stencil build --docs --dev --watch --serve",
    "test": "stencil test --spec --e2e",
    "test.watch": "stencil test --spec --e2e --watchAll",
    "generate": "stencil generate"
  },
  "dependencies": {
    "@stencil/core": "^4.7.0"
  },
  "devDependencies": {
    "@stencil/sass": "^2.0.0",
    "@types/jest": "^29.5.6",
    "@types/node": "^16.18.11",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "puppeteer": "21.1.1"
  }
}
