---
interface Props {
  react?: string;
  webComponent?: string;
}

const { react, webComponent } = Astro.props;
---
<pre class='doc-source'>
  {react && (
    <code>{react}</code>
  )}
  {webComponent && (
    <code>{webComponent}</code>
  )}
  <code><slot /></code>
</pre>

<style>
  .doc-source {
    background: slateblue;
    color: white;
    display: flex;
    flex-direction: column;
  }
</style>
